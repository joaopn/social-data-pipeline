# Parse profile user configuration
# Copy this file to user.yaml and uncomment/modify settings as needed.
#
# Structure: Each key corresponds to a config file (without .yaml extension).
# List values fully replace the base config (no merging).

# pipeline:                      # Overrides pipeline.yaml
#   processing:
#     data_types:                # Which data types to process
#       - submissions
#       - comments
#     parallel_mode: true        # If true: parse multiple files in parallel
#     parse_workers: 8           # Number of parallel workers for CSV parsing
#     cleanup_temp: false        # Delete intermediate files after processing
#     watch_interval: 0          # Check for new files every N minutes (0 = run once)
