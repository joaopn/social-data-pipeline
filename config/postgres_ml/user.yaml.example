# ML ingestion pipeline user configuration
# Copy this file to user.yaml and uncomment/modify settings as needed.
#
# Structure: Each key corresponds to a config file (without .yaml extension).
# Note: Field selection is now done in the ML profile (config/ml/), not here.
# The postgres_ml profile always ingests the full CSV file from the ML output.

# pipeline:                        # Overrides pipeline.yaml
#   database:
#     host: localhost              # Use localhost for external connections
#     port: 5432
#   processing:
#     type_inference_rows: 500     # Fewer rows for faster inference
#     parallel_ingestion: true     # Ingest submissions and comments concurrently
#     use_foreign_key: true        # Add FK constraint to main table (default: true)
#                                  # Set false for independent ingestion without main table
#     watch_interval: 60           # Watch mode: check every 60 minutes

# services:                        # Overrides services.yaml
#   classifiers:
#     lingua:
#       enabled: false             # Disable lingua ingestion
#       column_overrides:          # Force specific column types for table creation
#         lang: text
#         lang2: text
#     
#     toxic_roberta:
#       enabled: true
#       source_dir: toxic_roberta
#       suffix: "_toxicity_en"     # Used for both file matching and table name
#     
#     go_emotions:
#       enabled: true
#       source_dir: go_emotions
#       suffix: "_emotions"
